{
  "name": "stefans-creative-bots",
  "version": "1.0.0",
  "description": "Beep beep tweet!",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:js": "rollup -c",
    "build:css": "sass src/styles/styles.scss:public/styles/main.css --style=compressed --no-source-map --quiet-deps",
    "build:critical": "node scripts/build-critical.js",
    "watch": "rollup -c --watch",
    "start": "node --trace-warnings server.js",
    "dev": "concurrently \"sass --watch src/styles/styles.scss:public/styles/main.css --quiet-deps\" \"rollup -c --watch\" \"nodemon --trace-warnings server.js\"",
    "test": "node test.js",
    "xxxpreinstall": "npm install canvas@2.11.2; npm install chartjs-node-canvas@4.1.6; npm install chart.js@3.9.1",
    "xxxpostinstall": "node node_modules/puppeteer/install.js; pip3 install yt-dlp==2023.7.6"
  },
  "dependencies": {
    "base64-stream": "^1.0.0",
    "body-parser": "^1.19.0",
    "bufferutil": "^4.0.1",
    "canvas": "^2.11.2",
    "chart.js": "^3.9.1",
    "chartjs-node-canvas": "^4.1.6",
    "cheerio": "^0.22.0",
    "color-scheme": "^1.0.1",
    "colorthief": "^2.4.0",
    "compromise": "^14.14.4",
    "concat-stream": "^2.0.0",
    "cron": "^2.4.3",
    "csv-parse": "^5.5.0",
    "csvtojson": "^2.0.10",
    "dotenv": "^16.3.1",
    "express": "^4.14.0",
    "express-handlebars": "^7.1.2",
    "express-session": "^1.17.3",
    "feed": "^5.2.1",
    "ffprobe": "^1.1.2",
    "ffprobe-static": "^3.1.0",
    "find-remove": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "get-google-fonts": "^1.2.2",
    "get-mp3-duration": "^1.0.0",
    "gifencoder": "^2.0.1",
    "glitch-canvas": "^1.1.8",
    "grant-express": "^4.7.0",
    "he": "^1.2.0",
    "hh-mm-ss": "^1.2.0",
    "html-entities": "^1.2.1",
    "html-to-text": "^8.x",
    "indefinite": "^2.4.3",
    "jsdom": "^16.2.2",
    "mastodon-api": "^1.2.2",
    "mastodon-api-v1": "^1.0.0",
    "memorystore": "^1.6.2",
    "moment": "^2.29.4",
    "node-blob": "^0.0.2",
    "node-fetch": "^2.7.0",
    "node-gyp": "^7.1.2",
    "node-gyp-build": "^4.2.3",
    "node-html-parser": "^7.1.0",
    "pluralize": "^8.0.0",
    "pngjs": "^4.0.0",
    "poisson-disc-sampler": "^1.1.0",
    "puppeteer": "^8.0.0",
    "q": "1.0.1",
    "request": "^2.88.2",
    "rivescript": "^2.2.1",
    "roughjs": "^4.1.4",
    "tough-cookie": "^4.0.0",
    "tracery-grammar": "^2.7.4",
    "underscore": "^1.10.2",
    "us-zips": "^4.0.1",
    "utf-8-validate": "^5.0.2",
    "wtf_wikipedia": "^10.4.1",
    "xml-js": "^1.6.11"
