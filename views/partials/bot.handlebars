<div class="card mb-4 w-100">

  <div class="bot-card-banner">
    {{#if about.fediverse_url}}
    <a href="{{about.fediverse_url}}"
      data-fediverse-url="{{about.fediverse_url}}"
      rel="me noopener noreferrer"
      target="_blank"
      class="d-block w-100 h-100">
      {{/if}}
      {{#if about.header_image}}
      <img src="{{about.header_image}}"
        alt="{{about.name}} banner"
        loading="lazy">
      {{else if about.thumbnail}}
      <img src="{{about.thumbnail}}"
        alt="{{about.name}} banner"
        loading="lazy">
      {{else}}
      <img
        src="https://generative-placeholders.stefanbohacek.com/image?width=600&height=200&style=cellular-automata&cells=10&colors={{@root.generative_placeholders_color}}&{{@key}}"
        alt="{{about.name}} banner"
        loading="lazy">
      {{/if}}
      {{#if about.fediverse_url}}
    </a>
    {{/if}}
  </div>

  <div class="card-body">
    {{#if about.fediverse_url}}
    <a href="{{about.fediverse_url}}"
      data-fediverse-url="{{about.fediverse_url}}"
      rel="me noopener noreferrer"
      target="_blank">
      {{/if}}
      {{#if about.avatar}}
      <img src="{{about.avatar}}"
        width="64"
        height="64"
        class="rounded-circle bot-avatar"
        alt="{{about.name}} avatar"
        loading="lazy">
      {{else}}
      <img
        src="https://generative-placeholders.stefanbohacek.com/image?width=200&height=200&style=cellular-automata&cells=10&colors={{@root.generative_placeholders_color}}&{{@key}}"
        width="64"
        height="64"
        class="rounded-circle bot-avatar"
        alt="{{about.name}} avatar"
        loading="lazy">
      {{/if}}
      {{#if about.fediverse_url}}
    </a>
    {{/if}}

    <div class="mt-2 mb-3">
      <h2 class="fs-5 mb-0">{{about.name}}</h2>
      {{#if about.fediverse_handle}}
      <small class="text-muted d-block mb-1">{{about.fediverse_handle}}</small>
      {{/if}}
      <div class="mt-1">
        {{#if about.created_year}}
        <span class="badge badge-year me-1" data-date-created="{{about.date_created}}">Created in {{about.created_year}}</span>
        {{/if}}
        <span class="followers-count badge bg-info text-black d-none"></span>
      </div>
    </div>

    <p>{{about.description}}</p>

    <ul class="list-unstyled">
      {{#if about.active}}
      {{#if about.reply}}
      <li>
        <span title="This bot replies to you">💬</span> Reply bot
      </li>
      {{/if}}
      {{#if about.interval_human}}
      <li>
        <small><strong>Frequency:</strong> {{about.interval_human}}</small>
      </li>
      {{/if}}
      {{#if about.interval}}
      <li class="d-none">
        <small><strong>Next run:</strong> <time data-handle="{{about.fediverse_handle}}" data-run-type="next"></time></small>
      </li>
      <li class="d-none">
        <small><strong>Last run:</strong> <time data-handle="{{about.fediverse_handle}}" data-run-type="last"></time></small>
      </li>
      {{/if}}
      {{/if}}
    </ul>

    <ul class="bot-links mb-0 ps-3">
      {{#each about.links}}
      {{#if this.is_fediverse}}
      <li>
        <a rel="me noopener noreferrer"
          target="_blank"
          class="fw-bold"
          data-fediverse-url="{{this.url}}"
          href="{{this.url}}">{{this.title}}</a>
      </li>
      {{else}}
      <li>
        <a rel="me noopener noreferrer"
          target="_blank"
          href="{{this.url}}">{{this.title}}</a>
      </li>
      {{/if}}
      {{/each}}
      {{#if about.source_url}}
      <li>
        <a rel="me noopener noreferrer"
          target="_blank"
          href="{{about.source_url}}">View source<span class="visually-hidden"> for the {{about.name}} bot</span></a>
      </li>
      {{/if}}
      {{#if about.about_url}}
      <li>
        <a rel="me noopener noreferrer"
          target="_blank"
          href="{{about.about_url}}">Learn more<span class="visually-hidden"> about the {{about.name}} bot</span></a>
      </li>
      {{/if}}
    </ul>

    {{#if about.note}}
    <div class="card mt-3">
      <div class="card-body">
        <small>{{about.note}}</small>
      </div>
    </div>
    {{/if}}

  </div>

  {{#if about.tags}}
  <div class="card-footer pb-3">
    {{#each about.tags}}
    <span class="badge text-bg-secondary">#{{this}}</span>
    {{/each}}
  </div>
  {{/if}}

</div>